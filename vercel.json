{
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/tts.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/tts", "destination": "/api/tts.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
